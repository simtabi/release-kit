# Auto detect text files + normalise to LF
* text=auto eol=lf

*.py     text diff=python
*.json   text
*.toml   text
*.yml    text
*.yaml   text
*.md     text
*.sh     text eol=lf
*.ps1    text eol=crlf

# Binary
*.png    binary
*.jpg    binary
*.jpeg   binary
*.gif    binary
*.ico    binary
*.pdf    binary
*.zip    binary
*.tar.gz binary
*.whl    binary
